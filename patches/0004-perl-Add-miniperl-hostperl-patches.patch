diff --git a/patches/packages/packages/0003-perl-do-not-set-LD_LIBRARY_PATH-for-cross-compile.patch b/patches/packages/packages/0003-perl-do-not-set-LD_LIBRARY_PATH-for-cross-compile.patch
new file mode 100644
index 0000000000000000000000000000000000000000..4d5939c5d02a9fe2d5d74ab3094feb4ef69d8f46
--- /dev/null
+++ b/patches/packages/packages/0003-perl-do-not-set-LD_LIBRARY_PATH-for-cross-compile.patch
@@ -0,0 +1,240 @@
+From: Matthias Schiffer <mschiffer@universe-factory.net>
+Date: Mon, 12 May 2025 18:42:41 +0200
+Subject: perl: do not set LD_LIBRARY_PATH for cross compile
+
+We don't want to set LD_LIBRARY_PATH to a directory filled with target
+libraries when running a host perl. When the host and target
+architecture are the same, some libraries will be loaded from this
+path, resulting in the build to break because of glibc/musl mismatch.
+
+Reported-by: John Audia <therealgraysky@proton.me>
+Fixes: e7b5a35e5caa ("perl: drop 110-always_use_miniperl.patch")
+Signed-off-by: Matthias Schiffer <mschiffer@universe-factory.net>
+(cherry picked from commit 67669398926f85796e73919974ce290eecd5d3e6)
+
+diff --git a/lang/perl/patches/101-cross-compile-ldlibpth.patch b/lang/perl/patches/101-cross-compile-ldlibpth.patch
+new file mode 100644
+index 0000000000000000000000000000000000000000..4ea0e3e4f47757daf9971e6cd6ea8c4c486c4b33
+--- /dev/null
++++ b/lang/perl/patches/101-cross-compile-ldlibpth.patch
+@@ -0,0 +1,15 @@
++--- a/Makefile.SH
+++++ b/Makefile.SH
++@@ -174,6 +174,12 @@ EOT
++ 		;;
++ 	esac
++ 
+++	case "$usecrosscompile$perl" in
+++	define?*)
+++	        ldlibpth=''
+++		;;
+++	esac
+++
++ 	;;
++ 
++ *)	pldlflags=''
+diff --git a/lang/perl/patches/900-use-rm-force.patch b/lang/perl/patches/900-use-rm-force.patch
